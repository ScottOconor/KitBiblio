generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String?   @unique
  password      String
  firstName     String?
  lastName      String?
  avatar        String?
  bio           String?
  role          UserRole  @default(USER)
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  courses     Course[]
  books       Book[]
  enrollments Enrollment[]
  purchases   Purchase[]
  reviews     Review[]
  bookmarks   Bookmark[]
  progress    Progress[]
  payments    Payment[]

  @@map("users")
}

enum UserRole {
  USER
  INSTRUCTOR
  ADMIN
  SUPER_ADMIN
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  color       String?
  type        String   @default("both")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Course[]
  books   Book[]

  @@map("categories")
}

model Book {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  description   String
  shortDesc     String?
  cover         String?
  price         Float
  originalPrice Float?
  currency      String     @default("XAF")
  language      String     @default("fr")
  pages         Int?
  format        BookFormat @default(PDF)
  fileSize      Int?
  isbn          String?    @unique
  publisher     String?
  paymentLink   String?
  publishDate   DateTime?
  rating        Float      @default(0)
  reviewsCount  Int        @default(0)
  downloads     Int        @default(0)
  isPublished   Boolean    @default(true)
  isFree        Boolean    @default(false)
  categoryId    String
  authorId      String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  category  Category   @relation(fields: [categoryId], references: [id])
  author    User       @relation(fields: [authorId], references: [id])
  purchases Purchase[]
  reviews   Review[]
  bookmarks Bookmark[]

  @@map("books")
}

enum BookFormat {
  PDF
  EPUB
  MOBI
  AUDIOBOOK
}

model Course {
  id             String      @id @default(cuid())
  title          String
  slug           String      @unique
  description    String
  shortDesc      String?
  thumbnail      String?
  price          Float
  originalPrice  Float?
  currency       String      @default("EUR")
  language       String      @default("fr")
  level          CourseLevel @default(BEGINNER)
  duration       Int         @default(0)
  lessonsCount   Int         @default(0)
  studentsCount  Int         @default(0)
  rating         Float       @default(0)
  reviewsCount   Int         @default(0)
  isPublished    Boolean     @default(true)
  isFree         Boolean     @default(false)
  hasCertificate Boolean     @default(false)
  paymentLink    String?
  categoryId     String
  instructorId   String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  category    Category     @relation(fields: [categoryId], references: [id])
  instructor  User         @relation(fields: [instructorId], references: [id])
  enrollments Enrollment[]
  purchases   Purchase[]
  reviews     Review[]
  bookmarks   Bookmark[]
  progress    Progress[]

  @@map("courses")
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Enrollment {
  id              String           @id @default(cuid())
  userId          String
  courseId        String
  status          EnrollmentStatus @default(ACTIVE)
  overallProgress Float            @default(0)
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  course   Course     @relation(fields: [courseId], references: [id])
  progress Progress[]

  @@unique([userId, courseId])
  @@map("enrollments")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

model Purchase {
  id            String         @id @default(cuid())
  userId        String
  courseId      String?
  bookId        String?
  amount        Float
  currency      String         @default("XAF")
  status        PurchaseStatus @default(COMPLETED)
  paymentMethod String?        @default("lygos")
  paymentId     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  course  Course?  @relation(fields: [courseId], references: [id])
  book    Book?    @relation(fields: [bookId], references: [id])
  payment Payment?

  @@map("purchases")
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id         String        @id @default(cuid())
  userId     String
  purchaseId String        @unique
  amount     Float
  currency   String        @default("XAF")
  status     PaymentStatus @default(COMPLETED)
  provider   String        @default("lygos")
  providerId String?
  metadata   Json?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id])

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

model Review {
  id         String   @id @default(cuid())
  userId     String
  courseId   String?
  bookId     String?
  rating     Int
  comment    String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  course Course? @relation(fields: [courseId], references: [id])
  book   Book?   @relation(fields: [bookId], references: [id])

  @@unique([userId, courseId])
  @@unique([userId, bookId])
  @@map("reviews")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  courseId  String?
  bookId    String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  course Course? @relation(fields: [courseId], references: [id])
  book   Book?   @relation(fields: [bookId], references: [id])

  @@unique([userId, courseId])
  @@unique([userId, bookId])
  @@map("bookmarks")
}

model Progress {
  id           String         @id @default(cuid())
  userId       String
  courseId     String?
  enrollmentId String?
  status       ProgressStatus @default(IN_PROGRESS)
  progress     Float          @default(0)
  timeSpent    Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  course     Course?     @relation(fields: [courseId], references: [id])
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id])

  @@unique([userId, courseId])
  @@map("progress")
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}
